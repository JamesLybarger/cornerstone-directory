# Stripe — get these from dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook Secret — get from dashboard.stripe.com/webhooks after adding your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# Your live domain once deployed
APP_URL=https://cornerstonedirectory.com

# Set to production on Railway
NODE_ENV=production

# Port — Railway sets this automatically, but 5000 is the default
PORT=5000
